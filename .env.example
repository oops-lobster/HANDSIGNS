# Copy this file to .env and fill in your API keys.
PORT=3000

# Gemini rewrites Korean sentences into sign-language API search terms.
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_RATE_LIMIT_PER_CLIENT_PER_MINUTE=6

# Optional fallback Culture Portal API key. Source-specific keys are preferred.
CULTURE_API_KEY=
CULTURE_API_INTEGRATED_KEY=
CULTURE_API_LIFE_KEY=
CULTURE_API_SPECIALIZED_KEY=
CULTURE_API_CULTURE_KEY=

# Optional endpoint overrides.
CULTURE_API_LIFE_URL=https://api.kcisa.kr/openapi/service/rest/meta13/getCTE01701
CULTURE_API_SPECIALIZED_URL=https://api.kcisa.kr/openapi/service/rest/meta13/getCTE01702
CULTURE_API_CULTURE_URL=https://api.kcisa.kr/openapi/service/rest/meta13/getCTE01703
CULTURE_API_INTEGRATED_URL=https://api.kcisa.kr/API_CNV_054/request

# Adjust these if the API document uses different parameter names.
CULTURE_API_KEY_PARAM=serviceKey
CULTURE_API_QUERY_PARAM=keyword
CULTURE_API_FORMAT_PARAM=format
CULTURE_API_FORMAT=
CULTURE_API_PAGE_SIZE_PARAM=numOfRows
CULTURE_API_PAGE_SIZE=5

# Optional Google Apps Script webhook for MVP feedback logs.
FEEDBACK_LOG_WEBHOOK_URL=
