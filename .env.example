# Copy this file to .env and fill in your Culture Portal API details.
PORT=3000

# Example:
# CULTURE_API_BASE_URL=https://www.culture.go.kr/openapi/rest/publicperformancedisplays/...
CULTURE_API_BASE_URL=
CULTURE_API_KEY=

# Adjust these if the API document uses different parameter names.
CULTURE_API_KEY_PARAM=serviceKey
CULTURE_API_QUERY_PARAM=keyword
CULTURE_API_FORMAT_PARAM=format
CULTURE_API_FORMAT=json
